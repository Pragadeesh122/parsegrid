# ============================================
# ParseGrid Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- Auth (shared secret between Next.js Auth.js and FastAPI) ---
AUTH_SECRET=your-auth-secret-here-min-32-chars-long

# --- FastAPI Backend ---
FASTAPI_ENV=development
DATABASE_URL=postgresql+asyncpg://parsegrid:parsegrid@localhost:5432/parsegrid
REDIS_URL=redis://localhost:6379/0

# --- S3-Compatible Storage (MinIO locally, AWS S3 in prod) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=parsegrid-uploads
S3_REGION=us-east-1

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key

# --- LlamaParse ---
LLAMA_CLOUD_API_KEY=llx-your-llamaparse-key

# --- Next.js Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
